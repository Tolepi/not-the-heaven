# --- Configuración Básica de Sway (Zero Mono White Edition) ---

# Tecla Mod (Super/Windows)
set $mod Mod4

# Direcciones tradicionales de Vim
set $left h
set $down j
set $up k
set $right l

# Aplicaciones por defecto
set $term kitty
set $menu wofi --show drun --normal-window --lines 10 --width 400

# --- Estética y Bordes (Estilo Tiling Estricto) ---
default_border pixel 2
default_floating_border none
gaps inner 2
gaps outer 2

# Paleta de colores para las ventanas (Blanco, Gris y Negro)
# class                 border  backgr. text    indicator child_border
client.focused          #000000 #ffffff #000000 #000000   #000000
client.focused_inactive #aaaaaa #ffffff #444444 #aaaaaa   #aaaaaa
client.unfocused        #e5e5e5 #ffffff #777777 #e5e5e5   #e5e5e5
client.urgent           #000000 #ffffff #000000 #000000   #000000

# --- Keybinds Principales ---

# Iniciar aplicaciones
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu

# Matar ventana enfocada
bindsym $mod+q kill

# Recargar / Salir de Sway
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m '¿Quieres salir de Sway?' -B 'Sí, salir' 'swaymsg exit'

# --- Movimiento de Foco ---
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# Forzar a que ciertas aplicaciones o ventanas nuevas aparezcan flotando por defecto
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable
for_window [window_type="dialog"] floating enable

# --- Controles de Mouse para Ventanas Flotantes ---
# Mantén presionada la tecla Super ($mod) y arrastra con el clic izquierdo para mover, o clic derecho para redimensionar.
floating_modifier $mod

# --- Keybind para Alternar Estado ---
# Con esto cambias la ventana enfocada actual entre modo Tiling y modo Flotante instantáneamente.
bindsym $mod+Shift+space floating toggle

# Alternativa con flechas de dirección
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# --- Mover Ventanas ---
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# --- Modos de Layout ---
# Dividir en horizontal/vertical
bindsym $mod+b splith
bindsym $mod+v splitv

# Estilos de disposición
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Pantalla completa
bindsym $mod+f fullscreen toggle

# Cambiar entre modo flotante y tiling (por si acaso)
bindsym $mod+space focus mode_toggle

# --- Workspaces ---
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"

# Cambiar de Workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9

# Mover contenedor al Workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9

# --- Modo de Redimensionado (Resize) ---
mode "resize" {
    bindsym $left resize shrink width 10 px
    bindsym $down resize grow height 10 px
    bindsym $up resize shrink height 10 px
    bindsym $right resize grow width 10 px

    bindsym Left resize shrink width 10 px
    bindsym Down resize grow height 10 px
    bindsym Up resize shrink height 10 px
    bindsym Right resize grow width 10 px

    # Volver al modo normal
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# --- Teclas de Medios (Audio/Brillo) ---
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

# --- Autostart ---
# Barra de estado inferior
bar {
    swaybar_command waybar
}

# Fondo de pantalla blanco sólido
exec swaybg -i /home/mint/Descargas/mint.png

### Screenshot
bindsym $mod+Print exec grim -g "$(slurp)" /home/mint/Imágenes/screenshot_$(date +%Y%m%d_%H%M%S).png
